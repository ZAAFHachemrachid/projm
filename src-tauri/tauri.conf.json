{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/main/crates/tauri-config-schema/schema.json",
  "productName": "Projm",
  "version": "0.7.4",
  "identifier": "com.projm.desktop",
  "build": {
    "frontendDist": "../app/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../app && npm run dev",
    "beforeBuildCommand": "cd ../app && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Projm — Project Organizer",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5OUNBQ0NDODMwRUM3MjYKUldRbXh3NkR6S3ljYVlSTks5U28vSDk4MFRDbDNxL3J4b2EvM00rbUVxVVBOVW5DWHBZc3Z1SFUK",
      "endpoints": [
        "https://github.com/ZAAFHachemrachid/projm/releases/download/desktop-latest/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
